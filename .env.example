ENV=development

# Required in every environment: use at least 32 random characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# NUXT_JWT_SECRET is the canonical runtime variable. JWT_SECRET is accepted for local compatibility.
NUXT_JWT_SECRET=

# SMTP configuration for e-mail verification.
# Nuxt also accepts these at runtime under the NUXT_EMAIL_* names.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=SHCK Video <no-reply@example.com>

# Public URL used in verification links.
APP_URL=http://localhost:3000

# Set to true only when a trusted reverse proxy replaces X-Forwarded-For.
# This lets the rate limiter identify the original client IP without trusting
# spoofable headers from direct clients.
TRUST_PROXY=false
