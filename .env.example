ENV=development

# Required in every environment: use a long random value.
JWT_SECRET=replace-with-a-long-random-secret

# SMTP configuration for e-mail verification.
# Nuxt also accepts these at runtime under the NUXT_EMAIL_* names.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=SHCK Video <no-reply@example.com>

# Public URL used in verification links.
APP_URL=http://localhost:3000
